{
  "name": "eui-goccia",
  "version": "1.0.0",
  "description": "EUI Goccia",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm payload migrate &&  next build --webpack",
    "dev": "pnpm payload migrate && next dev --turbopack",
    "devsafe": "pnpm payload migrate && rm -rf .next && next dev",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "payload generate:types",
    "fix": "pnpm dlx ultracite fix",
    "typecheck": "tsc --noEmit",
    "payload": "payload",
    "start": "next start",
    "db:up": "docker compose -f docker-compose.db.yml up -d",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "db:purge": "docker compose -f docker-compose.db.yml down -v && rm -rf payload.sqlite",
    "cleanup": "pnpm db:purge && pnpm db:up && rm -rf .next node_modules pnpm-lock.yaml",
    "sync:media": "bash scripts/sync-media.sh",
    "pull:prod": "bash scripts/pull-prod.sh"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@payloadcms/db-sqlite": "^3.81.0",
    "@payloadcms/live-preview-react": "^3.81.0",
    "@payloadcms/next": "^3.81.0",
    "@payloadcms/plugin-import-export": "^3.81.0",
    "@payloadcms/plugin-nested-docs": "^3.81.0",
    "@payloadcms/plugin-seo": "^3.81.0",
    "@payloadcms/richtext-lexical": "^3.81.0",
    "@payloadcms/storage-s3": "^3.81.0",
    "@payloadcms/translations": "^3.81.0",
    "@payloadcms/ui": "^3.81.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.1",
    "framer-motion": "^12.38.0",
    "graphql": "^16.13.2",
    "lenis": "^1.3.21",
    "libsql": "^0.5.29",
    "lucide-react": "^1.7.0",
    "mapbox-gl": "^3.21.0",
    "next": "^16.2.2",
    "next-intl": "^4.9.0",
    "payload": "^3.81.0",
    "plaiceholder": "^3.0.0",
    "postcss": "^8.5.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-player": "^3.4.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "lint-staged": "^16.4.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "ultracite": "7.1.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm dlx ultracite fix"
    ]
  }
}
