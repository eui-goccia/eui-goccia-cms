# Payload CMS
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_VERCEL_URL=http://localhost:3000
ALLOWED_ORIGINS=
PAYLOAD_SECRET=
PREVIEW_SECRET=
CRON_SECRET=
DATABASE_URL="file:payload.sqlite"
# DATABASE_AUTH_TOKEN=

# Production/source database for scripts/pull-prod.sh only.
# Deployed runtime may use TURSO_DATABASE_URL only when DATABASE_URL is unset.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Production/source media for scripts/sync-media.sh only.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Minio (S3 Storage)
S3_ENDPOINT=http://localhost:9000 # Minio endpoint
S3_BUCKET=media # You need to create this bucket in Minio
S3_ACCESS_KEY_ID=minio_root_user # In production, you should use a dedicated key id
S3_SECRET_ACCESS_KEY=minio_root_password # In production, you should use a dedicated access key
S3_REGION="us-east-1" # Fake region

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=
